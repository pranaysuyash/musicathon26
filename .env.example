# Sample env — copy to .env and fill real values. .env is gitignored.
# DO NOT commit real keys.

# Musixmatch Pro (lyrics foundation)
MUSIXMATCH_API_KEY=your_key_here
MUSIXMATCH_PASSWORD=your_password_here

# Songstats (chart / popularity / cultural weight)
SONGSTATS_API_KEY=your_key_here

# Hugging Face (EmbeddingGemma / GLiNER / sentence-transformers downloads)
HF_TOKEN=your_token_here

# ElevenLabs (one narrated insight per query)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Cyanite (audio mood / genre / energy)
CYANITE_API_KEY=

# LALAL.AI (optional stem split for uploads)
LALAL_AI_API_KEY=

# JamBase (live / tour / venue geography)
JAMBASE_API_KEY=
