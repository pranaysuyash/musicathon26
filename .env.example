# Sample env — copy to .env and fill real values. .env is gitignored.
# DO NOT commit real keys.

# Musixmatch Pro (lyrics foundation)
MUSIXMATCH_API_KEY=your_key_here
MUSIXMATCH_PASSWORD=your_password_here

# Songstats (chart / popularity / cultural weight)
SONGSTATS_API_KEY=your_key_here

# Hugging Face (EmbeddingGemma / GLiNER / sentence-transformers downloads)
# `HF_TOKEN` is preferred; `HUGGINGFACE_API_KEY` is also supported as an alias.
HF_TOKEN=your_token_here
# HUGGINGFACE_API_KEY=

# ElevenLabs (one narrated insight per query)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Cyanite (audio mood / genre / energy)
CYANITE_WEBHOOK_SECRET=
# CYANITE_API_KEY=

# LALAL.AI (optional stem split for uploads)
LALAL_AI_API_KEY=

# JamBase (live / tour / venue geography)
JAMBASE_API_KEY=

# Genius (optional lyric fallback when Musixmatch fails)
# To enable: register a free API client at https://genius.com/api-clients
# Required fields when registering:
#   App Name:        VerseSignal (or your project name)
#   Icon URL:        https://your-domain/og-image.png  (any URL works for read-only)
#   App Website URL: https://your-domain              (your deployed demo URL)
#   Redirect URI:    https://your-domain/callback     (not strictly needed for read-only)
# Paste the resulting access token below:
GENIUS_ACCESS_TOKEN=
